{
  "name": "taxwise-desktop",
  "version": "1.0.0",
  "description": "TaxWise - Nigerian Tax Management & Compliance System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run watch\" \"wait-on dist/index.html && electron .\"",
    "watch": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "jest"
  },
  "build": {
    "appId": "com.taxwise.desktop",
    "productName": "TaxWise",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "database/**/*",
      "node_modules/sql.js/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "protocols": [
      {
        "name": "TaxWise",
        "schemes": [
          "taxwise"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "tvst-dev",
        "repo": "taxwise-desktop",
        "private": true
      }
    ]
  },
  "keywords": [
    "tax",
    "nigeria",
    "paye",
    "cit",
    "vat",
    "withholding-tax",
    "accounting",
    "finance"
  ],
  "author": "TaxWise Team",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "wait-on": "^7.0.1",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.0",
    "crypto-js": "^4.1.1",
    "date-fns": "^2.30.0",
    "docx": "^8.2.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.3.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.6.0",
    "lucide-react": "^0.263.1",
    "openai": "^4.11.0",
    "pdfjs-dist": "^3.11.174",
    "pdfmake": "^0.2.7",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-datepicker": "^4.21.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.16.0",
    "sql.js": "^1.8.0",
    "uuid": "^9.0.0",
    "zustand": "^4.4.1"
  }
}
